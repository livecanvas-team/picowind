{
    "name": "devtheorem\/php-handlebars",
    "description": "A blazing fast, spec-compliant PHP implementation of Handlebars.",
    "keywords": [
        "handlebars",
        "mustache",
        "template",
        "render",
        "parse",
        "compile"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Theodore Brown",
            "email": "theodorejb@outlook.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "devtheorem\/php-handlebars-parser": "^2.1"
    },
    "require-dev": {
        "friendsofphp\/php-cs-fixer": "^3.95",
        "jbboehr\/handlebars-spec": "dev-master",
        "phpstan\/phpstan": "^2.1.51",
        "phpunit\/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "PicowindDeps\\DevTheorem\\Handlebars\\": "src\/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PicowindDeps\\DevTheorem\\Handlebars\\Test\\": "tests\/"
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@analyze",
            "@cs-check"
        ],
        "analyze": "phpstan analyze",
        "cs-check": "php-cs-fixer check -v",
        "cs-fix": "php-cs-fixer fix -v",
        "test": "phpunit tests"
    },
    "config": {
        "platform": {
            "php": "8.2.29"
        },
        "sort-packages": true
    }
}